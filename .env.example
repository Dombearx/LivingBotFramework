# Copy this file to .env and fill in your own values.

# Discord bot token used to connect the bot and the admin dashboard.
DISCORD_BOT_TOKEN=

# OpenRouter API key for all LLM calls.
OPENROUTER_API_KEY=

# Optional: override the OpenRouter base URL (defaults to the public endpoint).
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# RunPod credentials for image generation (selfies and photos).
RUNPOD_ENDPOINT_URL=
RUNPOD_API_KEY=
